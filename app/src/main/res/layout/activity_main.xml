<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AutoSpin">
    <!-- res/layout/activity_main.xml -->


    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/animasi2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_x="-1dp"
            android:layout_y="-6dp"
            android:scaleType="fitXY" />
    </WebView>

    <ImageView
        android:id="@+id/animasi1"
        android:layout_width="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:layout_height="match_parent" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_alignParentTop="true"
        android:visibility="gone"
        style="?android:attr/progressBarStyleHorizontal" />

    <FrameLayout
        android:id="@+id/draggableGroup"
        android:layout_marginLeft="20dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        >

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_marginLeft="20dp"
            android:layout_height="match_parent">
            <RelativeLayout
                android:id="@+id/sliderof"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

            <Switch
                android:id="@+id/kondisisaklar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FCFEFF"
                android:layout_marginTop="50dp"
                android:textSize="11sp"
                android:layout_marginLeft="85dp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:ignore="UseSwitchCompatOrMaterialXml" />



            <ImageView
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginLeft="10dp"
                android:src="@drawable/slider" />

            <ImageView
                android:id="@+id/slideron"
                android:layout_width="150dp"
                android:layout_height="130dp"
                android:visibility="gone"
                android:layout_marginLeft="25dp"
                android:src="@drawable/slider" />
                <ImageView
                    android:id="@+id/powermulaizeus"
                    android:layout_width="30dp"
                    android:layout_height="20dp"
                    android:text=""
                    android:visibility="gone"
                    android:src="@drawable/offwsitch"
                    android:textColor="#FCFEFF"
                    android:layout_marginTop="82dp"
                    android:textSize="11sp"
                    android:layout_marginLeft="80dp"/>
                <TextView
                    android:id="@+id/textpola"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI ENGINE\nPENCARI POLA"
                    android:src="@drawable/offwsitch"
                    android:textColor="#FCFEFF"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_marginTop="60dp"
                    android:textSize="10sp"
                    android:layout_marginLeft="65dp"/>

                <ImageView
                android:id="@+id/powermulai"
                android:layout_width="30dp"
                android:layout_height="20dp"
                android:text=""
                android:src="@drawable/offwsitch"
                android:textColor="#FCFEFF"
                android:layout_marginTop="82dp"
                android:textSize="11sp"
                android:layout_marginLeft="80dp"/>
            <ImageView
                android:id="@+id/powerstop"
                android:layout_width="30dp"
                android:layout_height="20dp"
                android:text=""
                android:visibility="gone"
                android:src="@drawable/onswitch"
                android:textColor="#FCFEFF"
                android:layout_marginTop="82dp"
                android:textSize="11sp"
                android:layout_marginLeft="80dp"/>
            </RelativeLayout>
        </RelativeLayout>
            <ImageView
                android:id="@+id/icon"
                android:layout_width="80dp"
                android:layout_marginTop="40dp"
                android:layout_height="80dp"
                android:src="@drawable/sebelumaktif"
                android:scaleType="centerCrop" />


    </FrameLayout>
    <!-- TextView untuk menampilkan koordinat sentuhan -->
    <TextView
        android:id="@+id/touchCoordinates"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|left"
        android:padding="8dp"
        android:textSize="16sp"
        android:textColor="#FF0000"
        tools:ignore="RtlHardcoded" />
</RelativeLayout>
